  {
    "id": "JgHGKb8y1rnJ",
    "stageId": "stage_Er4P3ODp",
    "title": "Quick Check: Numerator vs Denominator",
    "order": 5,
    "actions": [
      {
        "id": "action_Op5ObS8W",
        "type": "speech",
        "text": "Let's check what we just learned."
      },
      {
        "id": "action_WJWqMW0Z",
        "type": "speech",
        "text": "Read each question carefully."
      },
      {
        "id": "action_y8M1t4Bp",
        "type": "speech",
        "text": "Take your time."
      }
    ],
    "createdAt": 1777912996541,
    "updatedAt": 1777912996541,
    "type": "quiz",
    "content": {
      "type": "quiz",
      "questions": [
        {
          "id": "q1",
          "type": "single",
          "question": "In the fraction 5/8, which is the numerator?",
          "options": [
            {
              "value": "A",
              "label": "5"
            },
            {
              "value": "B",
              "label": "8"
            },
            {
              "value": "C",
              "label": "both"
            }
          ],
          "correctAnswer": "A",
          "answer": [
            "A"
          ],
          "hasAnswer": true
        },
        {
          "id": "q2",
          "type": "single",
          "question": "In the fraction 3/7, which is the denominator?",
          "options": [
            {
              "value": "A",
              "label": "3"
            },
            {
              "value": "B",
              "label": "7"
            },
            {
              "value": "C",
              "label": "neither"
            }
          ],
          "correctAnswer": "B",
          "answer": [
            "B"
          ],
          "hasAnswer": true
        },
        {
          "id": "q3",
          "type": "single",
          "question": "Which fraction has 4 equal parts?",
          "options": [
            {
              "value": "A",
              "label": "1/3"
            },
            {
              "value": "B",
              "label": "1/4"
            },
            {
              "value": "C",
              "label": "1/5"
            }
          ],
          "correctAnswer": "B",
          "answer": [
            "B"
          ],
          "hasAnswer": true
        }
      ]
    }
  },
  {
    "id": "aperVpBPpzmj",
    "stageId": "stage_Er4P3ODp",
    "title": "Fraction Builder Simulation",
    "order": 6,
    "actions": [
      {
        "id": "action_noADNSXU",
        "type": "speech",
        "title": "intro",
        "text": "Let's build a fraction together by adjusting the sliders."
      },
      {
        "id": "action_K7WNHdAY",
        "type": "widget_highlight",
        "title": "slider",
        "target": "#numerator-slider"
      },
      {
        "id": "action_K7WNHdAY_speech",
        "type": "speech",
        "title": "slider",
        "text": "This top slider sets the numerator."
      },
      {
        "id": "action_CuKi6sxq",
        "type": "speech",
        "title": "explain",
        "text": "Watch how the display updates as you slide."
      }
    ],
    "createdAt": 1777912996543,
    "updatedAt": 1777912996543,
    "type": "interactive",
    "content": {
      "type": "interactive",
      "url": "",
      "html": "<!DOCTYPE html><html><head><title>Fraction Builder</title><script type=\"application/json\" id=\"widget-config\">{\"engine\":\"vanilla\",\"variables\":[\"numerator\",\"denominator\"]}</script>\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css\">\n<script src=\"https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js\"></script>\n<script>\ndocument.addEventListener(\"DOMContentLoaded\", function() {\n    const katexOptions = {\n        delimiters: [\n            {left: '\\\\[', right: '\\\\]', display: true},\n            {left: '\\\\(', right: '\\\\)', display: false},\n            {left: '$$', right: '$$', display: true},\n            {left: '$', right: '$', display: false}\n        ],\n        throwOnError: false,\n        strict: false,\n        trust: true\n    };\n\n    let renderTimeout;\n    function safeRender() {\n        if (renderTimeout) clearTimeout(renderTimeout);\n        renderTimeout = setTimeout(() => {\n            renderMathInElement(document.body, katexOptions);\n        }, 100);\n    }\n\n    renderMathInElement(document.body, katexOptions);\n\n    const observer = new MutationObserver((mutations) => {\n        let shouldRender = false;\n        mutations.forEach((mutation) => {\n            if (mutation.target &&\n                mutation.target.className &&\n                typeof mutation.target.className === 'string' &&\n                mutation.target.className.includes('katex')) {\n                return;\n            }\n            shouldRender = true;\n        });\n\n        if (shouldRender) {\n            safeRender();\n        }\n    });\n\n    observer.observe(document.body, {\n        childList: true,\n        subtree: true,\n        characterData: true\n    });\n\n    setInterval(() => {\n        const text = document.body.innerText;\n        if (text.includes('\\\\(') || text.includes('$$')) {\n            safeRender();\n        }\n    }, 2000);\n});\n</script>\n</head><body><div id=\"app\"><h2>Fraction Builder</h2><div>Numerator: <input id=\"numerator-slider\" type=\"range\" min=\"0\" max=\"8\"></div><div>Denominator: <input id=\"denominator-slider\" type=\"range\" min=\"1\" max=\"12\"></div><div id=\"display\">0/1</div></div></body></html>",
      "widgetType": "simulation",
      "widgetConfig": {
        "engine": "vanilla",
        "variables": [
          "numerator",
          "denominator"
        ]
      },
      "teacherActions": [
        {
          "type": "speech",
          "label": "intro",
          "content": "Let's build a fraction together by adjusting the sliders."
        },
        {
          "type": "highlight",
          "label": "slider",
          "target": "#numerator-slider",
          "content": "This top slider sets the numerator."
        },
        {
          "type": "speech",
          "label": "explain",
          "content": "Watch how the display updates as you slide."
        }
      ]
    }
  },
